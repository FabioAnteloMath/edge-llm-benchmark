# stubs. We only need the symbols actually used by our code.
from typing import Any

def __getattr__(name: str) -> Any: ...

class ndarray:
    def tolist(self) -> list[object]: ...

class integer: ...
class floating: ...
class bool_: ...
class _ScalarLike: ...

def isfinite(x: object) -> bool: ...

# Integer/float subclasses used as type-checked values
class int64(integer): ...
class float64(floating): ...
class float32(floating): ...
