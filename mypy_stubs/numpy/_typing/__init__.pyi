# Minimal numpy stub — sidesteps Python 3.12+ syntax in numpy 2.5's official
# stubs. We only need the symbols actually used by our code.
from typing import Any

def __getattr__(name: str) -> Any: ...

class ndarray: ...

class integer: ...
class floating: ...
class bool_: ...

def isfinite(x: object) -> bool: ...

class int64(integer): ...
class float64(floating): ...
class float32(floating): ...
